apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: argo-app2
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://github.com/patilpreet21/argocd-child-app2.git
    targetRevision: HEAD
    path: childapp2
  destination:
    server: https://kubernetes.default.svc
    namespace: default
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
